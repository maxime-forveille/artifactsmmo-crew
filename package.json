{
  "name": "artifactsmmo-bot",
  "version": "0.0.1",
  "private": true,
  "description": "Personal TypeScript bot for managing a 5-character crew in Artifacts MMO.",
  "keywords": [
    "artifactsmmo",
    "bot",
    "typescript"
  ],
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "generate:api-types": "tsx scripts/generateApiTypes.ts",
    "start": "node --env-file=.env dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "tsx scripts/runMutationTests.ts",
    "test:mutation:dry": "tsx scripts/runMutationTests.ts --dryRunOnly",
    "test:watch": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "neverthrow": "^8.2.0",
    "openapi-fetch": "^0.17.0",
    "pino": "^10.3.1",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "msw": "^2.15.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0"
    },
    "runtime": {
      "name": "node",
      "version": "24.17.0"
    }
  },
  "engines": {
    "node": "24.17.0",
    "npm": "please-use-pnpm",
    "pnpm": "11.9.0",
    "yarn": "please-use-pnpm"
  },
  "packageManager": "pnpm@11.9.0"
}
